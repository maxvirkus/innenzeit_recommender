# Shared password for the app login (choose something strong)
APP_PASSWORD=change-me

# Random secret used as the session cookie value. Generate e.g. with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Supabase project credentials (Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
# Service role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ElevenLabs text-to-speech (used only by `npm run generate:audio`)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Voice id from your ElevenLabs voice library
ELEVENLABS_VOICE_ID=your-voice-id
# Optional model override (default: eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
