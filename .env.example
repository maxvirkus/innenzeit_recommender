# Shared password for the app login (choose something strong)
APP_PASSWORD=change-me

# Random secret used as the session cookie value. Generate e.g. with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Supabase project credentials (Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
# Service role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
